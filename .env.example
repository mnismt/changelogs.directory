# App
VITE_BASE_URL="http://localhost:5173"

# Database (PostgreSQL)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/changelogs"

# Redis (Upstash)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Auth (Better Auth)
BETTER_AUTH_SECRET=""
BETTER_AUTH_URL=http://localhost:5173

# GitHub (for changelog ingestion)
GITHUB_TOKEN=""

# Analytics (PostHog)
VITE_PUBLIC_POSTHOG_KEY=""
VITE_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Error Tracking (Sentry) - optional
VITE_SENTRY_DSN=""
VITE_SENTRY_ENVIRONMENT="dev"
SENTRY_DSN=""
SENTRY_ENVIRONMENT="dev"

# Email (Resend)
RESEND_API_KEY=""

# LLM (for AI-powered parsing)
GEMINI_API_KEY=""

# Observability (Braintrust) - optional
BRAINTRUST_API_KEY=""
PROJECT_NAME=Changelogs

# Admin
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD=""

# Admin HTTP API (e.g. GET /api/latest). Send as Authorization: Bearer <key> or X-Admin-Api-Key: <key>
ADMIN_API_KEY=""

# Trigger.dev (background jobs)
TRIGGER_SECRET_KEY=""
TRIGGER_PROJECT_ID=""

# Vercel (for Trigger.dev env sync) - optional
VERCEL_ACCESS_TOKEN=""
VERCEL_PROJECT_ID=""

# Dev tools
VITE_DEVTOOLS_ENABLED=false
