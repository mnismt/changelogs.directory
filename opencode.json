{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "playwright": {
      "type": "local",
      "command": ["npx", "-y", "@playwright/mcp", "--headless"],
      "enabled": true
    },
    "sentry": {
      "type": "local",
      "command": ["npx", "-y", "mcp-remote@latest", "https://mcp.sentry.dev/mcp"],
      "enabled": true
    }
  },
  "tools": {
    "playwright_*": false,
    "sentry_*": false
  },
  "agent": {
    "plan": {
      "model": "proxypal/gemini-claude-opus-4-5-thinking"
    },
    "explore": {
      "model": "proxypal/gemini-3-flash-preview"
    }
  }
}
