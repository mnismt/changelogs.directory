generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Waitlist {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now()) @map("created_at")

  @@index([email])
  @@index([createdAt(sort: Desc)])
  @@map("waitlist")
}

model User {
  id            String    @id
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @default(now()) @updatedAt
  banExpires    DateTime?
  banReason     String?
  banned        Boolean?
  role          String?
  accounts      Account[]
  sessions      Session[]

  @@map("user")
}

model Session {
  id             String   @id
  expiresAt      DateTime
  token          String   @unique
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  ipAddress      String?
  userAgent      String?
  userId         String
  impersonatedBy String?
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt

  @@map("verification")
}

model Tool {
  id            String     @id @default(cuid())
  slug          String     @unique
  name          String
  vendor        String
  description   String?
  homepage      String
  repositoryUrl String
  sourceType    SourceType
  sourceUrl     String
  sourceConfig  Json?
  logoUrl       String?
  tags          String[]
  isActive      Boolean    @default(true)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  lastFetchedAt DateTime?
  fetchLogs     FetchLog[]
  releases      Release[]

  @@index([slug])
  @@index([isActive])
  @@index([lastFetchedAt])
  @@map("tool")
}

model Release {
  id           String    @id @default(cuid())
  toolId       String
  version      String
  versionSort  String
  releaseDate  DateTime?
  publishedAt  DateTime  @default(now())
  sourceUrl    String
  rawContent   String
  contentHash  String
  title        String?
  summary      String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  isPrerelease Boolean   @default(false)
  headline     String
  changes      Change[]
  tool         Tool      @relation(fields: [toolId], references: [id], onDelete: Cascade)

  @@unique([toolId, version])
  @@index([toolId, isPrerelease])
  @@index([toolId, releaseDate(sort: Desc)])
  @@index([publishedAt(sort: Desc)])
  @@map("release")
}

model Change {
  id            String       @id @default(cuid())
  releaseId     String
  type          ChangeType
  title         String
  description   String?
  platform      String?
  component     String?
  isBreaking    Boolean      @default(false)
  isSecurity    Boolean      @default(false)
  isDeprecation Boolean      @default(false)
  impact        ImpactLevel?
  links         Json?
  order         Int          @default(0)
  createdAt     DateTime     @default(now())
  media         Json?
  release       Release      @relation(fields: [releaseId], references: [id], onDelete: Cascade)

  @@index([releaseId, order])
  @@index([type])
  @@index([isBreaking])
  @@index([isSecurity])
  @@index([platform])
  @@map("change")
}

model FetchLog {
  id              String      @id @default(cuid())
  toolId          String
  status          FetchStatus
  startedAt       DateTime    @default(now())
  completedAt     DateTime?
  duration        Int?
  releasesFound   Int         @default(0)
  releasesNew     Int         @default(0)
  releasesUpdated Int         @default(0)
  changesCreated  Int         @default(0)
  error           String?
  errorStack      String?
  sourceUrl       String
  sourceEtag      String?
  tool            Tool        @relation(fields: [toolId], references: [id], onDelete: Cascade)

  @@index([toolId, startedAt(sort: Desc)])
  @@index([status])
  @@map("fetch_log")
}

model EmailLog {
  id        String   @id @default(cuid())
  to        String
  subject   String
  status    String
  provider  String
  error     String?
  createdAt DateTime @default(now())

  @@index([to])
  @@index([status])
  @@index([createdAt(sort: Desc)])
  @@map("email_log")
}

enum SourceType {
  CHANGELOG_MD
  GITHUB_RELEASES
  RSS_FEED
  CUSTOM_API
}

enum ChangeType {
  FEATURE
  BUGFIX
  IMPROVEMENT
  BREAKING
  SECURITY
  DEPRECATION
  PERFORMANCE
  DOCUMENTATION
  OTHER
}

enum ImpactLevel {
  MAJOR
  MINOR
  PATCH
}

enum FetchStatus {
  PENDING
  IN_PROGRESS
  SUCCESS
  FAILED
  PARTIAL
}
